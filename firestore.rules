rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function isOwner(u) { return isAuth() && uid() == u; }

    // Read the caller's user document — cached per request by Firestore
    function me() { return get(/databases/$(database)/documents/users/$(uid())).data; }

    function isMentor() { return isAuth() && me().role == 'mentor' && me().isVerifiedMentor == true; }
    function isAdmin()  { return isAuth() && me().role == 'admin'; }
    function isMod()    { return isAdmin() || isMentor(); }

    // Disabled users cannot write anything
    function notDisabled() { return !('disabled' in me()) || me().disabled != true; }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Anyone authenticated can read user profiles (for display names etc.)
    // Users can update their own profile, but cannot change role or isVerifiedMentor
    // Only admins can set those fields or delete users
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && notDisabled()
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'isVerifiedMentor', 'disabled']))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Daily content (read-only for users, admin-write) ──────────────────────
    match /dailyDevotions/{id} { allow read: if true; allow write: if isAdmin(); }
    match /dailyPrayers/{id}   { allow read: if true; allow write: if isAdmin(); }

    // ── Scripture library ─────────────────────────────────────────────────────
    // Mentors and admins can add. Only admin or the mentor who added can delete.
    match /scriptures/{id} {
      allow read:   if true;
      allow create: if isMod() && notDisabled();
      allow update: if isMod() && notDisabled();
      allow delete: if isAdmin() || (isAuth() && resource.data.addedBy == uid());
    }

    // ── Prayer requests (user-generated) ─────────────────────────────────────
    match /prayerRequests/{id} {
      allow read:   if isAuth();
      allow create: if isAuth() && notDisabled()
                    && request.resource.data.uid == uid();
      // Owner can mark answered; anyone can toggle prayedFor/prayedCount; admin can edit all
      allow update: if isAuth() && (
          resource.data.uid == uid()
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['prayedFor', 'prayedCount'])
          || isAdmin()
        );
      allow delete: if isAuth() && (resource.data.uid == uid() || isAdmin());
    }

    // ── Prayer points (mentor/admin) ──────────────────────────────────────────
    match /prayerPoints/{id} {
      allow read:   if isAuth();
      allow create: if isMod() && notDisabled();
      allow update: if isMod() && notDisabled();
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == uid());
    }

    // ── User reminders (private) ──────────────────────────────────────────────
    match /userReminders/{userId} {
      allow read, write: if isOwner(userId) && notDisabled();
    }

    // ── Reflections (private to owner) ────────────────────────────────────────
    match /reflectionEntries/{id} {
      allow read:   if isAuth() && resource.data.uid == uid();
      allow create: if isAuth() && notDisabled() && request.resource.data.uid == uid();
      allow update, delete: if isAuth() && resource.data.uid == uid();
    }

    // ── User daily progress ───────────────────────────────────────────────────
    match /userProgress/{id} {
      allow read:  if isAuth() && resource.data.uid == uid();
      allow write: if isAuth() && notDisabled() && request.resource.data.uid == uid();
    }

    // ── Pathway levels (mentor/admin editable) ────────────────────────────────
    match /pathwayLevels/{id} {
      allow read:   if true;
      allow create: if isMod() && notDisabled();
      allow update: if isMod() && notDisabled();
      allow delete: if isAdmin();
    }

    // ── Pathway lessons (mentor/admin editable) ───────────────────────────────
    match /pathwayLessons/{id} {
      allow read:   if true;
      allow create: if isMod() && notDisabled();
      allow update: if isMod() && notDisabled();
      allow delete: if isMod();
    }

    // ── Lesson progress (private) ─────────────────────────────────────────────
    match /lessonProgress/{id} {
      allow read:  if isAuth() && resource.data.uid == uid();
      allow write: if isAuth() && notDisabled() && request.resource.data.uid == uid();
    }

    // ── Community posts ───────────────────────────────────────────────────────
    // Users post reflections; mentors/admins post teachings
    match /communityPosts/{postId} {
      allow read: if true;
      allow create: if isAuth() && notDisabled()
                    && request.resource.data.userId == uid()
                    && (request.resource.data.type == 'reflection' || isMod());
      allow update: if isAuth() && (
          resource.data.userId == uid()
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amenCount', 'amenedBy'])
          || isAdmin()
        );
      allow delete: if isAuth() && (resource.data.userId == uid() || isAdmin());

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if isAuth() && notDisabled()
                      && request.resource.data.uid == uid();
        allow delete: if isAuth() && (resource.data.uid == uid() || isAdmin());
      }
    }

    // ── Videos ───────────────────────────────────────────────────────────────
    match /videos/{id} {
      allow read:   if true;
      allow create: if isMod() && notDisabled();
      allow update: if isMod() && notDisabled();
      allow delete: if isAdmin();
    }

    // ── Video progress (private) ──────────────────────────────────────────────
    match /videoProgress/{id} {
      allow read:  if isAuth() && resource.data.uid == uid();
      allow write: if isAuth() && notDisabled() && request.resource.data.uid == uid();
    }

    // ── Reports (users submit, only admins read/update) ───────────────────────
    match /reports/{id} {
      allow create: if isAuth() && notDisabled()
                    && request.resource.data.reporterId == uid();
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
